<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize Font Customer. -->
        <item name="fontFamily">@font/ubuntu_regular</item>
        <item name="android:fontFamily">@font/ubuntu_regular</item>

        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <!-- Resume Style-->
    <declare-styleable name="Resume">
        <attr name="backGroundColor" format="color"/>
        <attr name="initialNumber" format="integer"/>
        <attr name="finalNumber" format="integer" />
        <attr name="textColor" format="color"/>
        <attr name="textSize" format="dimension"/>
        <attr name="backgroundDrawable" format="reference"/>
    </declare-styleable>
    <!-- Resume Style-->

    <style name="buttonAccount" >
        <item name="android:background">@drawable/bg_btn_green</item>
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/ubuntu_medium</item>
    </style>

    <style name="styleBodyRed" >
        <item name="android:textColor">@color/colorInputError</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">@font/ubuntu_medium</item>
    </style>

    <style name="styleBodySmall" >
        <item name="android:textColor">@color/colorTextBodySmall</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/ubuntu_medium</item>
    </style>

    <style name="styleBodyMedium" >
        <item name="android:textColor">@color/colorTextBody</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/ubuntu_regular</item>
    </style>

    <style name="styleBodyMediumBold" >
        <item name="android:textColor">@color/colorTextBody</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/ubuntu_bold</item>
    </style>

    <style name="styleBody" >
        <item name="android:textColor">@color/colorTextBody</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/ubuntu_regular</item>
    </style>

    <style name="styleLabelInput" >
        <item name="android:textColor">@color/main_color</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">@font/ubuntu_medium</item>
    </style>

    <style name="styleLabelInputError" >
        <item name="android:textColor">@color/colorInputError</item>
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">@font/ubuntu_medium</item>
    </style>

    <style name="styleLabelAppearanceInputErrorBlack" parent="@android:style/TextAppearance">
        <item name="android:textColor">@color/black</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">@font/ubuntu_regular</item>
    </style>

    <style name="styleLabelAppearanceInputError" parent="@android:style/TextAppearance">
        <item name="android:textColor">@color/colorInputError</item>
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">@font/ubuntu_regular</item>
    </style>

    <style name="styleLabelAppearanceInputSuccess" parent="@android:style/TextAppearance">
        <item name="android:layout_marginTop">10dp</item>
        <item name="android:textSize">10sp</item>
        <item name="android:fontFamily">@font/ubuntu_regular</item>
    </style>

    <style name="styleTitleApp" >
        <item name="android:textColor">@color/colorWhite</item>
        <item name="android:textSize">20sp</item>
        <item name="android:gravity">center</item>
        <item name="android:fontFamily">@font/ubuntu_medium</item>
    </style>

    <style name="styleTitle" >
        <item name="android:textColor">@color/colorTextTitle</item>
        <item name="android:textSize">21sp</item>
        <item name="android:fontFamily">@font/ubuntu_medium</item>
    </style>


    <style name="styleH2" >
        <item name="android:textColor">@color/main_text_color</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">@font/ubuntu_bold</item>
    </style>

    <style name="styleH3" >
        <item name="android:textColor">@color/main_color</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/ubuntu_bold</item>
    </style>

    <style name="styleH3Medium" >
        <item name="android:textColor">@color/colorTextH2</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">@font/ubuntu_medium</item>
    </style>

    <style name="styleH3Bold" >
        <item name="android:textColor">@color/colorTextTitle</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/ubuntu_bold</item>
    </style>

    <style name="styleH1" >
        <item name="android:textColor">@color/colorTextTitle</item>
        <item name="android:textSize">28sp</item>
        <item name="android:fontFamily">@font/ubuntu_medium</item>
    </style>


    <style name="styleBodyAnalysis">
        <item name="android:textColor">#B0B6C7</item>
        <item name="android:textSize">11sp</item>
        <item name="android:fontFamily">@font/ubuntu_medium</item>
    </style>

    <style name="styleBodyShapeSpecial">
        <item name="android:textColor">#B0B6C7</item>
        <item name="android:textSize">9sp</item>
        <item name="android:fontFamily">@font/ubuntu_medium</item>
    </style>

</resources>